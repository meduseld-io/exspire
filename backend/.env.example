# ExSpire Backend Configuration
# Production: copy to /etc/exspire.env (chmod 600, owned by root)
PORT=3001
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
NOTIFICATION_FROM=your-email@gmail.com
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:your-email@gmail.com
JWT_SECRET=
